{
  "manifest_version": 3,
  "name": "Chingu — Free SOP Generator & Step-by-Step Guides",
  "version": "0.4.1",
  "description": "Free open source SOP tool. Record any workflow, get step-by-step guides with screenshots & PDF. No paywall. No seat min.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": ["http://localhost:9988/"],
  "web_accessible_resources": [
    { "resources": ["library.html", "viewer.html"], "matches": ["<all_urls>"] }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
